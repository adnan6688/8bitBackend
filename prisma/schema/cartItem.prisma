model CartITem {
    id       String @id @default(ulid())

    quantity Int?   @default(1)


    cartId String
    cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)
 
    foodId String?
    food   Food?   @relation(fields: [foodId], references: [id], onDelete: Cascade)

    @@index([cartId])
}
